# ── ThermoVisit — Variáveis de ambiente ──────────────────────────
# Configure estas três variáveis em: Vercel → Project → Settings → Environment Variables
# NUNCA commite o arquivo .env real no Git!

# URL do projeto Supabase
# Supabase → Settings → API → Project URL
SUPABASE_URL=https://SEU-PROJECT-ID.supabase.co

# Chave service_role (backend only — nunca no frontend!)
# Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXX

# Senha de sincronização do app (você define — mín. 20 caracteres)
# Esta mesma chave é digitada dentro do app em: Dados → Nuvem → Chave
APP_SYNC_KEY=crie-uma-senha-forte-aqui-minimo-20-chars
