# ─────────────────────────────────────────────────────────────
# Agri Vendas v10.3 — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA comite o .env.local no git.
# ─────────────────────────────────────────────────────────────

# Supabase — obtenha em: Settings → API → Project URL / Service Role Key
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave secreta de sincronização — escolha qualquer string e configure o mesmo valor no app
# ATENÇÃO: o nome na Vercel deve ser APP_SYNC_KEY (não SYNC_KEY)
# O frontend envia essa chave no header x-app-key para autenticar o sync
APP_SYNC_KEY=troque-por-uma-chave-longa-e-secreta-aqui

# Bucket de fotos no Supabase Storage (crie o bucket no painel)
SUPABASE_PHOTOS_BUCKET=photos

# URL pública do app (usada em links e redirects — sem barra no final)
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app

# Workspace padrão (opcional — usado como fallback)
NEXT_PUBLIC_DEFAULT_WORKSPACE=principal
