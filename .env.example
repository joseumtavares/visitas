# ─────────────────────────────────────────────────────────────
# Agri Vendas v10.3 — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA comite o .env.local no git.
#
# NOMES EXATOS usados na Vercel (não renomear):
#   SUPABASE_URL              → Project URL do Supabase
#   SUPABASE_SERVICE_ROLE_KEY → Service Role Key do Supabase (Settings → API)
#   APP_SYNC_KEY              → Chave secreta que você define no app
# ─────────────────────────────────────────────────────────────

# Supabase — obtenha em: Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase — obtenha em: Settings → API → Service Role Key  (NÃO usar anon key)
# ATENÇÃO: o nome correto é SUPABASE_SERVICE_ROLE_KEY (com _ROLE_)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave secreta de sincronização — qualquer string, deve ser igual no app e na Vercel
# ATENÇÃO: o nome correto na Vercel é APP_SYNC_KEY
APP_SYNC_KEY=troque-por-uma-chave-longa-e-secreta-aqui

# Bucket de fotos no Supabase Storage (crie o bucket no painel se não existir)
SUPABASE_PHOTOS_BUCKET=photos

# URL pública do app (sem barra no final)
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app

# Workspace padrão (opcional — usado como fallback)
NEXT_PUBLIC_DEFAULT_WORKSPACE=principal
